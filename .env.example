# .env.example

# --- データ取得サービス設定 ---

# 利用する取引所を指定します。bybit または bitget。
EXCHANGE=bybit

# Bitget利用時の商品タイプです。通常はUSDT無期限の usdt-futures を指定します。
BITGET_PRODUCT_TYPE=usdt-futures

# データ取得サービス（fetcher）のデータ取得間隔を秒単位で指定します。デフォルトは300秒（5分）です。
FETCH_INTERVAL_SECONDS=300

# データ取得サービス（fetcher）の同時実行数です。
# BybitはIPごとに5秒600リクエスト、BitgetはFunding Rate系APIがIPごとに1秒20リクエストです。
# Bitget利用時は20以下を推奨します。
CONCURRENCY_LIMIT=10
